# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
# NOTE: uv.lock files MUST be committed (reproducible installs on fresh Macs).
# Do NOT add uv.lock to this ignore list.

# Node
node_modules/
dist/
.vite/

# Environment / secrets
.env
*.env.local

# Storage (videos + counter state are local to each deployment).
# Layout is unified under recording-booth/backend/storage/booth-{1,2,3}/
# per .omc/plans/unify-booths-v2.md US-006. Contents ignored, but the
# booth-N/ scaffold itself is tracked via a committed .gitkeep so the
# directory structure survives a fresh clone.
#
# Note on the glob: we ignore `booth-*/*` (contents) not `booth-*/`
# (the directory itself). If the directory were ignored, git wouldn't
# descend into it and the `!…/.gitkeep` negation below would be
# silently ineffective — a common gitignore pitfall.
recording-booth/backend/storage/booth-*/*
!recording-booth/backend/storage/booth-*/.gitkeep
# Pre-migration tarballs produced by scripts/migrate-storage.sh — the
# script writes one per run before any mutation.
recording-booth/backend/storage/.backup-*.tar.gz

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# OMC tool state
.omc/
.claude/
