# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
# NOTE: uv.lock files MUST be committed (reproducible installs on fresh Macs).
# Do NOT add uv.lock to this ignore list.

# Node
node_modules/
dist/
.vite/

# Environment / secrets
.env
*.env.local

# Storage (videos are local to each deployment)
program-a-reels-booth/backend/storage/display/
program-a-reels-booth/backend/storage/instagram/
program-a-reels-booth/backend/storage/temp/
!program-a-reels-booth/backend/storage/.gitkeep

# Program B storage (scores are ephemeral per deployment)
program-b-pump-game/backend/storage/scores/
!program-b-pump-game/backend/storage/scores/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# OMC tool state
.omc/
.claude/
