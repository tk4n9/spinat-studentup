# ── Cloudflare R2 credentials ──────────────────────────
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=spinat-reels-booth

# Public URL for the R2 bucket (enable in R2 bucket settings → Public Access)
# Format: https://pub-xxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# How many days until QR download links expire (presigned URL fallback)
QR_EXPIRY_DAYS=7
